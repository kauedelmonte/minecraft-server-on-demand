# Arquivo de exemplo para configurar o backend remoto do stack principal.
# Copie para backend.hcl, ajuste os valores e rode:
# terraform init -reconfigure -backend-config=backend.hcl

bucket         = "REPLACE_WITH_BOOTSTRAP_STATE_BUCKET"
key            = "infra/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "REPLACE_WITH_BOOTSTRAP_LOCK_TABLE"
# profile      = "personal/minecraft" # Opcional para execução local
